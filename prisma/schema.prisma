generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Pipeline (public dashboard: map + table of buildings/projects) ───

model Project {
  id            String   @id @default(cuid())
  name          String
  borough       String // sub
  status        String // st: Completed Conversion | Under Construction | Planned Conversion | Potential Conversion | Ground-Up New Build | Lease-up
  category      String // ct: Office-to-Residential | Ground-Up New Build
  units         Int?
  sqft          Int?
  deliveryLabel String // d: year like "2027", or "TBD", "Lease-up"
  sponsor       String
  lender        String
  address       String?
  lat           Float
  lng           Float
  isRudin       Boolean @default(false)
  imageUrl      String

  // optional affordability breakdown (rare, e.g. 355 Lexington Ave)
  affPct  Float?
  mktU    Int?
  affU    Int?
  avgSf   Int?
  affBands Json? // [{ pctUnits, ami, studio, oneBr, twoBr }]

  // cross-reference into the comps dataset below
  compBuildingName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Comps / rent analytics (underwriting comparison tab) ───

model CompBuilding {
  id           String  @id @default(cuid())
  name         String  @unique
  propertyType String // Conversion | Primary | Market
  lat          Float?
  lng          Float?
  underwritten Boolean @default(false)
  note         String?
  totalN       Int?

  stats        CompBuildingStat[]
  quarterStats CompBuildingQuarterStat[]
  units        CompBuildingUnit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Per-building, per-quarter, per-unit-type snapshot — powers "Buildings Over Time"
// in the Custom Report tab. Sparser than CompBuildingStat (all-time); many
// building/quarter/unit-type cells will have no row at all, which is expected.
model CompBuildingQuarterStat {
  id           String       @id @default(cuid())
  buildingId   String
  building     CompBuilding @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  quarter      String // "Q3 2024"
  quarterOrder Int
  unitType     String

  avgRent Float?
  avgPsf  Float?
  n       Int // lease count backing this cell — shown in UI so users can judge reliability

  @@unique([buildingId, quarter, unitType])
}

model CompBuildingStat {
  id         String       @id @default(cuid())
  buildingId String
  building   CompBuilding @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  unitType   String // ST | ST+HO | 1BD | 1BD+HO | 1BD+2HO | 2BD | 2B+HO | 3BD

  avgRent Float?
  medRent Float?
  minRent Float?
  maxRent Float?
  nRent   Int?

  avgPsf Float?
  medPsf Float?
  minPsf Float?
  maxPsf Float?
  nPsf   Int?

  avgSf Float?
  medSf Float?
  minSf Float?
  maxSf Float?
  nSf   Int?

  @@unique([buildingId, unitType])
}

// AGG.ut_stats — aggregate across ALL comp buildings, by unit type
model OverallUnitStat {
  id       String @id @default(cuid())
  unitType String @unique

  avgRent Float?
  medRent Float?
  minRent Float?
  maxRent Float?
  nRent   Int?

  avgPsf Float?
  medPsf Float?
  minPsf Float?
  maxPsf Float?
  nPsf   Int?

  avgSf Float?
  medSf Float?
  minSf Float?
  maxSf Float?
  nSf   Int?
}

// AGG.pt_ut_stats — aggregate by property type x unit type
model TypeUnitStat {
  id           String @id @default(cuid())
  propertyType String // Conversion | Primary | Market
  unitType     String

  avgRent Float?
  medRent Float?
  minRent Float?
  maxRent Float?
  nRent   Int?

  avgPsf Float?
  medPsf Float?
  minPsf Float?
  maxPsf Float?
  nPsf   Int?

  @@unique([propertyType, unitType])
}

// AGG.trend — quarterly avg rent (and $/SF) by unit type, market-wide, for the trend chart
model TrendPoint {
  id           String @id @default(cuid())
  quarter      String // "Q3 2024"
  quarterOrder Int // sort key, e.g. 20243
  unitType     String
  avgRent      Float
  avgPsf       Float?

  @@unique([quarter, unitType])
}

// ─── Raw lease comp records (individual transactions from Rudin workbook) ───

model LeaseComp {
  id           String    @id @default(cuid())
  building     String
  unit         String?
  unitType     String?
  unitSf       Float?
  grossRent    Float?
  grossPsf     Float?
  netRent      Float?
  concession   Float?
  leaseDate    DateTime?
  quarter      String?
  propertyType String?
  createdAt    DateTime  @default(now())
}

// ─── App config ───

model SyncConfig {
  id                            Int       @id @default(1)
  projectsSheetUrl              String?
  compBuildingsSheetUrl         String?
  compBuildingStatsSheetUrl     String?
  compBuildingQuarterStatsSheetUrl String?
  overallStatsSheetUrl          String?
  typeStatsSheetUrl             String?
  trendSheetUrl                 String?
  lastSyncedAt                  DateTime?
}

// ─── Version snapshots ───

model Snapshot {
  id        String   @id @default(cuid())
  resource  String
  label     String
  data      Json
  createdAt DateTime @default(now())

  @@index([resource, createdAt])
}

// ─── Comp building unit inventory ───

model CompBuildingUnit {
  id             String      @id @default(cuid())
  buildingId     String
  building       CompBuilding @relation(fields: [buildingId], references: [id])
  unitName       String?
  unitNumber     String?
  unitType       String?
  floor          Int?
  sf             Float?
  bedrooms       Int?
  bathrooms      Float?
  askingRent     Float?
  netRent        Float?
  grossRent      Float?
  psf            Float?
  concessions    String?
  leaseDate      String?
  leaseStartDate String?
  leaseEndDate   String?
  leaseTerm      Int?
  status         String?
  notes          String?
  createdAt      DateTime @default(now())

  @@index([buildingId])
}
